<%- include('partials/header') %>

<main class="main-rgst">

    <div>
        <h1 class="fw-bold text-dark mb-5 text-start">Register Below</h1>
        
        <div class="row">
            <div class="col-sm-8 mr-5">
                <p class="text-secondary text-start mb-4">Simply create an account with your email.<br>
                    Password must be at least 6 characters, inluding lowercase, uppercase letters, digits and symbols.
                </p>
                <form action="/register" method="POST">
                    <div class="form-group text-start text-muted">
                    <label for="username">Name (optional)</label>
                    <input type="text" class="form-control text-start" name="username">
                    </div>
                    <div class="form-group text-start text-muted">
                    <label for="useremail">Email</label>
                    <input type="email" class="form-control text-start" name="useremail">
                    </div>
                    <div class="form-group text-start text-muted">
                    <label for="password">Password</label>
                    <input type="password" class="form-control text-start" name="password">
                    </div>
                    <button type="submit" class="btn btn-dark mt-4 d-flex">Register</button>
                </form>
            </div>

            <div class="col-sm-1 d-flex align-items-center justify-content-center">
                <p class="text-secondary">OR</p>
            </div>

            <!-- Google Sign-Up Button -->
            <div class="col-sm-3 d-flex align-items-center mb-3">
                <div
                    id="g_id_onload"
                    data-client_id="<%= GOOGLE_CLIENT_ID %>"
                    data-context="signup"
                    data-callback="handleCredentialResponse"
                    data-auto_prompt="false">
                </div>

                <div
                    class="g_id_signin"
                    data-type="standard"
                    data-shape="rectangular"
                    data-theme="outline"
                    data-text="signup_with"
                    data-size="large"
                    data-logo_alignment="left">
                </div>

                <script>
                    function handleCredentialResponse(response) {
                        console.log(response);

                        // response.credential is the Google ID token (JWT)
                        console.log(response.credential);

                        // Send the token to your backend
                        /*
                        fetch("/auth/google", {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json"
                            },
                            body: JSON.stringify({
                                credential: response.credential
                            })
                        });
                        */
                    }
                </script>
            </div>
        </div>

        <div class="mt-3">
            <p class="text-start" style="color: #dc3545;"><%= accountCheck %></p>
        </div>

    </div>

</main>

<%- include('partials/footer') %>