<%- include('partials/header') %>

<main class="main-rgst">

    <div>
        <h1 class="fw-bold text-dark mb-5 text-start">Register Below</h1>
        
        <div class="row">
            <div class="col-sm-8 mr-5">
                <p class="text-secondary text-start mb-4">Simply create an account with your email.<br>
                    Password must be at least 6 characters, inluding lowercase, uppercase letters, digits and symbols.
                </p>
                <form action="/register" method="POST">
                    <div class="form-group text-start text-muted">
                    <label for="username">Name (optional)</label>
                    <input type="text" id="username" class="form-control text-start" name="username">
                    </div>
                    <div class="form-group text-start text-muted">
                    <label for="useremail">Email</label>
                    <input type="email" id="useremail" class="form-control text-start" name="useremail">
                    </div>
                    <div class="form-group text-start text-muted">
                    <label for="password">Password</label>
                    <input type="password" id="password" class="form-control text-start" name="password">
                    </div>
                    <button type="submit" class="btn btn-dark mt-4 d-flex">Register</button>
                </form>
            </div>

            <div class="col-sm-1 d-flex align-items-center justify-content-center">
                <p class="text-secondary">OR</p>
            </div>

            <!-- Google Sign-Up Button -->
            <div class="col-sm-2 d-flex align-items-center mb-3">
                <a href="/auth/google" role="button" class="btn btn-outline-dark col-md-auto py-2">
                    <img
                    src="https://www.svgrepo.com/show/475656/google-color.svg"
                    width="20rem"
                    style="vertical-align: middle; margin-right:8px;">
                    Sign Up with Google
                </a>
            </div>
        </div>

        <div class="mt-3">
            <p class="text-start" style="color: #dc3545;"><%= accountCheck %></p>
        </div>

    </div>

</main>

<%- include('partials/footer') %>