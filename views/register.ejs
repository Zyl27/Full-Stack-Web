<%- include('partials/header') %>

<main class="main-rgst">

    <div>
        <h1 class="fw-bold text-dark mb-5 text-start">Register Below</h1>
        
        <div class="row">
            <div class="col-sm-8 mr-5">
                <p class="text-secondary text-start">Simply create an account with your email.<br>
                    Password must contain letters, numbers and at least a special character.
                </p>
                <form action="/register" method="POST">
                    <div class="form-group text-start text-muted">
                    <label for="email">Name (optional)</label>
                    <input type="email" class="form-control text-start" name="username">
                    </div>
                    <div class="form-group text-start text-muted">
                    <label for="email">Email</label>
                    <input type="email" class="form-control text-start" name="useremail">
                    </div>
                    <div class="form-group text-start text-muted">
                    <label for="password">Password</label>
                    <input type="password" class="form-control text-start" name="password">
                    </div>
                    <button type="submit" class="btn btn-dark mt-4 d-flex">Register</button>
                </form>
            </div>

            <div class="col-sm-1 d-flex align-items-center justify-content-center">
                <p class="text-secondary">OR</p>
            </div>

            <div class="col-sm-3 d-flex align-items-center mb-3">
                <div class="card" style="width: 20rem;">
                    <a class="btn btn-outline-dark" href="/auth/google" role="button">
                        <i class="fab fa-google"></i>
                        Sign up with Google
                    </a>
                </div>
            </div>
        </div>

    </div>

</main>

<%- include('partials/footer') %>